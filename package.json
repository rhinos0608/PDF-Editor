{
  "name": "professional-pdf-editor",
  "version": "1.0.0",
  "description": "Professional PDF Editor with comprehensive features",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "electron dist/main/main.js",
    "start-dev": "node run-dev.js",
    "start-fixed": "electron dist/main/main-fixed.js --disable-gpu",
    "start:safe": "set ELECTRON_DISABLE_GPU=1 && set ELECTRON_ENABLE_LOGGING=1 && set ELECTRON_FORCE_SOFTWARE_RENDERING=1 && electron dist/main/main.js --disable-gpu --disable-software-rasterizer --no-sandbox --use-gl=swiftshader",
    "start:gpu-fix": "node fix-gpu-and-launch.js",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "webpack --config webpack.main.config.js --mode development --watch",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development",
    "build": "node build.js",
    "build:fallback": "node build-production-enhanced-v4.js",
    "build:emergency": "node build-emergency.js",
    "build:main": "webpack --config webpack.main.config.js --mode production",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build:recovery": "node build-production-v5.js --recovery",
    "fix": "QUICK-FIX.bat",
    "master-build": "MASTER-BUILD.bat",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rimraf dist release",
    "clean:all": "rimraf dist release node_modules package-lock.json",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx"
  },
  "keywords": [
    "pdf",
    "editor",
    "electron",
    "react",
    "typescript"
  ],
  "author": "Professional PDF Editor Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.12",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "babel-loader": "^9.2.1",
    "concurrently": "^9.1.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.0",
    "electron": "^28.3.2",
    "electron-builder": "^25.1.8",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "process": "^0.11.10",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.2",
    "webpack": "^5.101.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.1"
  },
  "dependencies": {
    "@babel/preset-react": "^7.26.3",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@mui/material": "^6.3.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@types/bcrypt": "^6.0.0",
    "argon2": "^0.41.1",
    "bcrypt": "^6.0.0",
    "buffer": "^6.0.3",
    "dompurify": "^3.2.4",
    "electron-log": "^5.2.2",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "file-saver": "^2.0.5",
    "fs-extra": "^11.2.0",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.539.0",
    "path-browserify": "^1.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.54",
    "react": "^18.3.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^4.6.1",
    "react-resizable-panels": "^2.1.7",
    "react-toastify": "^9.1.3",
    "tesseract.js": "^5.1.1",
    "util": "^0.12.5",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "build": {
    "appId": "com.professional.pdfeditor",
    "productName": "Professional PDF Editor",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "!public/index.html",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png",
      "category": "Office"
    }
  }
}
